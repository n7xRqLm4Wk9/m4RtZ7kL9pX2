-- UI: Players Tab
PlayersTab:CreateSection("player list")
local playerListLabel = PlayersTab:CreateLabel("Player energy loading...")
task.spawn(function()
    while true do
        local lines = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            local energy = plr:GetAttribute("Energy")
            if energy then
                table.insert(lines, plr.Name .. ": " .. math.floor(energy) .. "%")
            end
        end
        playerListLabel:Set(#lines > 0 and table.concat(lines, "\n") or "No players with energy data")
        task.wait(2)
    end
end)
