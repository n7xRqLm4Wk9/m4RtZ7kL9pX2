-- Ghost ESP system
local ghostDrawings = {}  -- [ghostModel] = {lines, billboard}
local function updateGhostESP()
    -- Clean old drawings
    for model, data in pairs(ghostDrawings) do
        if not model.Parent then
            if data.lines then for _, l in ipairs(data.lines) do l:Remove() end end
            if data.billboard then data.billboard:Destroy() end
            ghostDrawings[model] = nil
        end
    end

    if not S.ghostESP then
        for _, data in pairs(ghostDrawings) do
            for _, l in ipairs(data.lines or {}) do l.Visible = false end
            if data.billboard then data.billboard.Enabled = false end
        end
        return
    end

    local ghostModel = workspace:FindFirstChild("Ghost")
    if not ghostModel then return end
    local head = ghostModel:FindFirstChild("Head") or ghostModel:FindFirstChild("HumanoidRootPart")
    if not head then return end
    local root = ghostModel:FindFirstChild("HumanoidRootPart") or head

    -- Create drawings if needed
    if not ghostDrawings[ghostModel] then
        local lines = {}
        if S.ghostBox then
            for i=1,4 do
                local l = Drawing.new("Line"); l.Visible = false; l.Thickness = 1.5; l.Color = Color3.new(0,1,1)
                table.insert(lines, l)
            end
        end
        if S.ghostTracer then
            local l = Drawing.new("Line"); l.Visible = false; l.Thickness = 1; l.Color = Color3.new(0,1,1)
            table.insert(lines, l)
        end
        local bb = Instance.new("BillboardGui")
        bb.AlwaysOnTop = true; bb.Size = UDim2.new(0,120,0,30); bb.StudsOffset = Vector3.new(0,3,0); bb.Adornee = head
        bb.Parent = CoreGui or player.PlayerGui
        local lbl = Instance.new("TextLabel", bb)
        lbl.Size = UDim2.new(1,0,1,0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(0,1,1); lbl.TextSize = 14; lbl.Font = Enum.Font.GothamBold
        ghostDrawings[ghostModel] = {lines = lines, billboard = bb, label = lbl}
    end

    local data = ghostDrawings[ghostModel]
    local lines = data.lines
    local bb = data.billboard
    local lbl = data.label
    bb.Enabled = true
    local ghostType = ghostModel:GetAttribute("GhostType") or "Unknown"
    local state = ghostModel:GetAttribute("State") or "Idle"
    local dist = math.floor((root.Position - camera.CFrame.Position).Magnitude)
    lbl.Text = ghostType .. " [" .. state .. "] " .. dist .. "m"

    local idx = 1
    -- Box
    if S.ghostBox and #lines >= 4 then
        local p1, on1 = camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.7,0))
        local p2, on2 = camera:WorldToViewportPoint(root.Position - Vector3.new(0,3,0))
        if on1 and on2 then
            local h = math.abs(p1.Y - p2.Y); local w = h * 0.55
            local cx, cy = p1.X, (p1.Y+p2.Y)/2
            local corners = {Vector2.new(cx-w/2,cy-h/2), Vector2.new(cx+w/2,cy-h/2), Vector2.new(cx+w/2,cy+h/2), Vector2.new(cx-w/2,cy+h/2)}
            for i=1,4 do lines[idx+i-1].From = corners[i]; lines[idx+i-1].To = corners[i%4+1]; lines[idx+i-1].Color = Color3.new(0,1,1); lines[idx+i-1].Visible = true end
        else for i=0,3 do lines[idx+i].Visible = false end end
        idx = idx + 4
    end
    -- Tracer
    if S.ghostTracer and #lines >= idx then
        local pos, on = camera:WorldToViewportPoint(root.Position)
        if on then lines[idx].From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y); lines[idx].To = Vector2.new(pos.X, pos.Y); lines[idx].Color = Color3.new(0,1,1); lines[idx].Visible = true
        else lines[idx].Visible = false end
    end
end
RunService.RenderStepped:Connect(updateGhostESP)

