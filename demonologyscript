-- Teleport to Ghost & Equip Tools
local function teleportAndEquip()
    local ghost = getGhost()
    if not ghost then Rayfield:Notify({Title = "Error", Content = "Ghost not found!", Duration = 3}) return end
    local root = ghost:FindFirstChild("HumanoidRootPart")
    local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if root and myRoot then myRoot.CFrame = root.CFrame + Vector3.new(3,0,0) end
    local tools = getRequiredTools()
    local events = ReplicatedStorage:FindFirstChild("Events")
    if events then
        for _, toolName in ipairs(tools) do
            pcall(function() events.ChangeSelectedItem:FireServer(toolName) end)
        end
        Rayfield:Notify({Title = "Tools", Content = "Equipped: " .. table.concat(tools, ", "), Duration = 4})
    end
end

