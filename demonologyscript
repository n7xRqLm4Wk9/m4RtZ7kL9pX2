-- Utility: find any object by name or attribute, recursively
local function findInWorkspace(name, attr, attrValue)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == name then
            if attr then
                if obj:GetAttribute(attr) == attrValue then return obj end
            else
                return obj
            end
        end
    end
    return nil
end

