-- Evidence ESP
local evidenceObjects = {}
local function updateEvidenceESP()
    for _, obj in ipairs(evidenceObjects) do
        if obj:IsA("Highlight") then obj:Destroy() end
        if obj:IsA("BillboardGui") then obj:Destroy() end
    end
    evidenceObjects = {}
    if not (S.evidenceESP or S.boneESP or S.cursedESP or S.handprintESP or S.orbESP or S.writingESP) then return end

    local patterns = {}
    if S.evidenceESP then patterns = {"Fingerprint","Handprint","Footprint","GhostOrb","GhostWriting","Writing","EMF","Thermometer","SpiritBox","Blacklight","UVLight","VideoCamera","PhotoEvidence","Freezing","DOTS","Projector","Withered","Plant"} end
    if S.handprintESP then table.insert(patterns,"Handprint"); table.insert(patterns,"Fingerprint"); table.insert(patterns,"Footprint") end
    if S.orbESP then table.insert(patterns,"GhostOrb") end
    if S.writingESP then table.insert(patterns,"GhostWriting"); table.insert(patterns,"Writing") end
    if S.boneESP then table.insert(patterns,"Bone") end
    if S.cursedESP then table.insert(patterns,"Cursed") end

    local seen = {}
    for _, pattern in ipairs(patterns) do
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Name:lower():find(pattern:lower()) and not seen[obj] then
                seen[obj] = true
                local hl = Instance.new("Highlight")
                hl.FillColor = (pattern:find("Bone") or pattern:find("Cursed")) and Color3.new(1,1,0) or Color3.new(0,1,0)
                hl.OutlineColor = Color3.new(1,1,1); hl.FillTransparency = 0.3; hl.Adornee = obj
                pcall(function() hl.Parent = CoreGui end)
                if not hl.Parent then hl.Parent = player:WaitForChild("PlayerGui") end
                table.insert(evidenceObjects, hl)
            end
        end
    end
    if S.cursedESP then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:GetAttribute("IsCursed") and not seen[obj] then
                seen[obj] = true
                local hl = Instance.new("Highlight"); hl.FillColor = Color3.new(1,0,1); hl.OutlineColor = Color3.new(1,1,1); hl.FillTransparency = 0.3; hl.Adornee = obj
                pcall(function() hl.Parent = CoreGui end)
                if not hl.Parent then hl.Parent = player:WaitForChild("PlayerGui") end
                table.insert(evidenceObjects, hl)
            end
        end
    end
end
task.spawn(function() while true do if S.evidenceESP or S.boneESP or S.cursedESP or S.handprintESP or S.orbESP or S.writingESP then updateEvidenceESP() end task.wait(5) end end)

