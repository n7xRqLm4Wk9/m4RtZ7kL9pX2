MiscTab:CreateSection("auto-execute on teleport")
MiscTab:CreateInput({Name = "Script URL", PlaceholderText = "Paste your script URL here...", RemoveTextAfterFocusLost = false, Flag = "AutoExecURL", Callback = function(Text)
    if Text and Text ~= "" then
        local qot = queue_on_teleport or syn and syn.queue_on_teleport or fluxus and fluxus.queue_on_teleport
        if qot then
            qot('loadstring(game:HttpGet("'..Text..'"))()')
            Rayfield:Notify({Title = "Auto Load", Content = "Script will auto-load on teleport.", Duration = 5})
        else
            Rayfield:Notify({Title = "Error", Content = "Your executor doesn't support queue_on_teleport.", Duration = 5})
        end
    end
end})

MiscTab:CreateSection("unload")
MiscTab:CreateButton({Name = "unload script (destroy all)", Callback = function()
    getgenv().DemonologyCyphraLoaded = nil
    if flyConn then flyConn:Disconnect() end
    if flyBodyGyro then flyBodyGyro:Destroy() end
    if flyBodyVelocity then flyBodyVelocity:Destroy() end
    for _, data in pairs(ghostDrawings) do
        if data.lines then for _, l in ipairs(data.lines) do pcall(l.Remove, l) end end
        if data.billboard then pcall(data.billboard.Destroy, data.billboard) end
    end
    ghostDrawings = {}
    updateCursedESP(); updateItemESP(); updatePlayerESP()
    Lighting.Ambient = Color3.fromRGB(12,12,12)
    Lighting.OutdoorAmbient = Color3.fromRGB(12,12,12)
    if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
        player.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = 16
    end
    Rayfield:Destroy()
end})

