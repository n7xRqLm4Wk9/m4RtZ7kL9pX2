-- Utility
local function getGhost()
    return workspace:FindFirstChild("Ghost")
end

local function getGhostAttribute(attr)
    local ghost = getGhost()
    return ghost and ghost:GetAttribute(attr)
end

-- Evidence Types mapping (from ghost module scripts)
local EVIDENCE_TO_TOOL = {
    ["EMFLevel5"] = "EMF Reader",
    ["SpiritBox"] = "Spirit Box",
    ["LaserProjector"] = "DOTS Projector",
    ["GhostOrb"] = "Video Camera",
    ["GhostWriting"] = "Ghost Writing Book",
    ["FreezingTemperatures"] = "Thermometer",
    ["Handprints"] = "UV Light",
    ["Wither"] = "Withered Plant",
}

local function getRequiredTools()
    local tools = {}
    local ghostType = getGhostAttribute("GhostType") or getGhostAttribute("Type")
    if not ghostType then return tools end
    local Modules = ReplicatedStorage:FindFirstChild("Modules")
    if not Modules then return tools end
    local ghostFolder = Modules:FindFirstChild(ghostType)
    if not ghostFolder then return tools end
    local ghostScript = ghostFolder:FindFirstChildOfClass("ModuleScript")
    if not ghostScript then return tools end
    local success, data = pcall(require, ghostScript)
    if not success or not data.Evidence then return tools end
    for _, ev in ipairs(data.Evidence) do
        local toolName = EVIDENCE_TO_TOOL[tostring(ev)]
        if toolName then table.insert(tools, toolName) end
    end
    return tools
end

