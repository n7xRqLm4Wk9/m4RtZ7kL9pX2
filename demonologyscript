-- UI: Ghost Tab
GhostTab:CreateSection("ghost info")
local ghostTypeLabel = GhostTab:CreateLabel("Ghost Type: Waiting...")
local ghostStateLabel = GhostTab:CreateLabel("Ghost State: Waiting...")
local ghostSpeedLabel = GhostTab:CreateLabel("Ghost Speed: --")
local ghostRoomLabel = GhostTab:CreateLabel("Favorite Room: --")
task.spawn(function()
    while true do
        local ghost = getGhost()
        if ghost then
            local ghostType = ghost:GetAttribute("GhostType") or ghost:GetAttribute("Type") or "Unknown"
            local state = ghost:GetAttribute("State") or "Idle"
            local speed = ghost:GetAttribute("GhostSpeed") or "--"
            local room = ghost:GetAttribute("FavoriteRoom") or ghost:GetAttribute("CurrentRoom") or "--"
            ghostTypeLabel:Set("Ghost Type: " .. ghostType)
            ghostStateLabel:Set("Ghost State: " .. state)
            ghostSpeedLabel:Set("Ghost Speed: " .. tostring(speed))
            ghostRoomLabel:Set("Favorite Room: " .. room)
        end
        task.wait(2)
    end
end)

