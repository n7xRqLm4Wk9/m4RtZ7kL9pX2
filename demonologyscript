    local ok, servers = pcall(function() return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?limit=100")) end)
    if ok and servers.data then
        for _, s in ipairs(servers.data) do
            if s.id ~= game.JobId then TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, player) return end
        end
    end
    Rayfield:Notify({Title = "Error", Content = "No server found", Duration = 3})
end})
MiscTab:CreateSection("utility")
MiscTab:CreateToggle({Name = "anti afk", CurrentValue = false, Flag = "AntiAFK", Callback = function(v)
    S.antiAFK = v
    if v then task.spawn(function() while S.antiAFK and getgenv().DemonologyCyphraLoaded do task.wait(60) if camera then camera.CFrame = camera.CFrame * CFrame.new(0,0,0.001) end end end) end
end})
MiscTab:CreateButton({Name = "open exit door", Callback = function()
    for _, model in ipairs(workspace:GetDescendants()) do
        if model:IsA("Model") and model.Name == "ExitDoor" then
            local door = model:FindFirstChild("Door")
            if door then ReplicatedStorage.Events.ClientChangeDoorState:FireServer(door) end
        end
    end
end})

