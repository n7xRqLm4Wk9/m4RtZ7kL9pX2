-- Fly (mobile‑friendly, uses move direction)
local flyConn, flyBodyGyro, flyBodyVelocity
local function stopFly()
    S.fly = false
    if flyConn then flyConn:Disconnect(); flyConn = nil end
    if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
    if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
    end
end
local function startFly()
    stopFly()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    S.fly = true
    hum.PlatformStand = true
    flyBodyGyro = Instance.new("BodyGyro"); flyBodyGyro.MaxTorque = Vector3.new(400000,400000,400000); flyBodyGyro.Parent = root
    flyBodyVelocity = Instance.new("BodyVelocity"); flyBodyVelocity.MaxForce = Vector3.new(400000,400000,400000); flyBodyVelocity.Velocity = Vector3.zero; flyBodyVelocity.Parent = root
    flyConn = RunService.RenderStepped:Connect(function()
        if not S.fly or not root or not root.Parent then stopFly(); return end
        local moveDir = (hum.MoveDirection * S.flySpeed)
        flyBodyVelocity.Velocity = moveDir
        flyBodyGyro.CFrame = camera.CFrame
    end)
end

