-- Evidence ESP (highlights fingerprints, orbs, writing, etc.)
local evidenceObjects = {}
local function updateEvidenceESP()
    for _, obj in ipairs(evidenceObjects) do
        if obj:IsA("Highlight") then obj:Destroy() end
        if obj:IsA("BillboardGui") then obj:Destroy() end
    end
    evidenceObjects = {}
    if not S.evidenceESP then return end

    local evidenceNames = {"Fingerprint", "GhostOrb", "GhostWriting", "EMF", "Thermometer", "SpiritBox", "UVLight", "VideoCamera", "PhotoEvidence"}
    for _, name in ipairs(evidenceNames) do
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Name == name then
                local hl = Instance.new("Highlight"); hl.FillColor = Color3.new(0,1,0); hl.OutlineColor = Color3.new(1,1,1); hl.Adornee = obj; hl.Parent = CoreGui or player.PlayerGui
                table.insert(evidenceObjects, hl)
            end
        end
    end
    -- Bone evidence
    if S.boneESP then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == "Bone" and obj:IsA("BasePart") then
                local hl = Instance.new("Highlight"); hl.FillColor = Color3.new(1,1,0); hl.OutlineColor = Color3.new(1,1,1); hl.Adornee = obj; hl.Parent = CoreGui or player.PlayerGui
                table.insert(evidenceObjects, hl)
            end
        end
    end
    -- Cursed object
    if S.cursedESP then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:GetAttribute("IsCursed") then
                local hl = Instance.new("Highlight"); hl.FillColor = Color3.new(1,0,1); hl.OutlineColor = Color3.new(1,1,1); hl.Adornee = obj; hl.Parent = CoreGui or player.PlayerGui
                table.insert(evidenceObjects, hl)
            end
        end
    end
end
task.spawn(function()
    while true do
        if S.evidenceESP or S.boneESP or S.cursedESP then updateEvidenceESP() end
        task.wait(5) -- refresh every 5 seconds to catch new spawns
    end
end)

