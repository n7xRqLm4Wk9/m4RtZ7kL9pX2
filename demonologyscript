-- Ghost ESP system
local ghostDrawings = {}
local function updateGhostESP()
    for model, data in pairs(ghostDrawings) do
        if not model.Parent then
            if data.lines then for _, l in ipairs(data.lines) do pcall(l.Remove, l) end end
            if data.billboard then pcall(data.billboard.Destroy, data.billboard) end
            ghostDrawings[model] = nil
        end
    end
    if not S.ghostESP then
        for _, data in pairs(ghostDrawings) do
            for _, l in ipairs(data.lines or {}) do if l then l.Visible = false end end
            if data.billboard then data.billboard.Enabled = false end
        end
        return
    end

    local ghostModel = getGhost()
    if not ghostModel then return end
    local head = ghostModel:FindFirstChild("Head") or ghostModel:FindFirstChild("HumanoidRootPart")
    if not head then return end
    local root = ghostModel:FindFirstChild("HumanoidRootPart") or head

    if S.rgbGhost then
        S.rgbHue = (S.rgbHue + 0.005) % 1
        S.ghostColor = Color3.fromHSV(S.rgbHue, 1, 1)
    end

    if not ghostDrawings[ghostModel] then
        local lines = {}
        if S.ghostBox then for i=1,4 do pcall(function() local l = Drawing.new("Line"); l.Visible=false; l.Thickness=1.5; l.Color=S.ghostColor; table.insert(lines,l) end) end end
        if S.ghostTracer then pcall(function() local l = Drawing.new("Line"); l.Visible=false; l.Thickness=1; l.Color=S.ghostColor; table.insert(lines,l) end) end
        local bb = Instance.new("BillboardGui")
        bb.AlwaysOnTop = true; bb.Size = UDim2.new(0,150,0,30); bb.StudsOffset = Vector3.new(0,3,0); bb.Adornee = head
        pcall(function() bb.Parent = CoreGui end)
        if not bb.Parent then bb.Parent = player:WaitForChild("PlayerGui") end
        local lbl = Instance.new("TextLabel", bb)
        lbl.Size = UDim2.new(1,0,1,0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = S.ghostColor; lbl.TextSize = 13; lbl.Font = Enum.Font.GothamBold
        ghostDrawings[ghostModel] = {lines = lines, billboard = bb, label = lbl}
    end

    local data = ghostDrawings[ghostModel]
    local lines = data.lines
    local bb = data.billboard
    local lbl = data.label
    bb.Enabled = S.ghostName
    if S.ghostName then
        local ghostType = ghostModel:GetAttribute("GhostType") or ghostModel:GetAttribute("Type") or ghostModel.Name or "Unknown"
        local state = ghostModel:GetAttribute("State") or "Idle"
        local dist = math.floor((root.Position - camera.CFrame.Position).Magnitude)
        lbl.Text = ghostType .. " [" .. state .. "] " .. dist .. "m"
        lbl.TextColor3 = S.ghostColor
    end

    local idx = 1
    if S.ghostBox and #lines >= idx+3 then
        local p1,on1 = camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.7,0))
        local p2,on2 = camera:WorldToViewportPoint(root.Position - Vector3.new(0,3,0))
        if on1 and on2 then
            local h = math.abs(p1.Y-p2.Y); local w = h*0.55
            local cx,cy = p1.X, (p1.Y+p2.Y)/2
            local corners = {Vector2.new(cx-w/2,cy-h/2), Vector2.new(cx+w/2,cy-h/2), Vector2.new(cx+w/2,cy+h/2), Vector2.new(cx-w/2,cy+h/2)}
            for i=1,4 do
                local l = lines[idx+i-1]
                if l then l.From = corners[i]; l.To = corners[i%4+1]; l.Color = S.ghostColor; l.Visible = true end
            end
        else
            for i=0,3 do if lines[idx+i] then lines[idx+i].Visible = false end end
        end
        idx = idx + 4
    end
    if S.ghostTracer and #lines >= idx then
        local pos, on = camera:WorldToViewportPoint(root.Position)
        local l = lines[idx]
        if l then
            if on then l.From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y); l.To = Vector2.new(pos.X,pos.Y); l.Color = S.ghostColor; l.Visible = true
            else l.Visible = false end
        end
    end
end
