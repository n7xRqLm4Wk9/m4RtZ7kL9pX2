-- ==================== ESP ====================
local espObjects = {}

local function clearESP()
    for _, e in pairs(espObjects) do
        if e.h then pcall(function() e.h:Destroy() end) end
        if e.b then pcall(function() e.b:Destroy() end) end
    end
    espObjects = {}
end

local function getDetailedLabel(model)
    local name = model:GetAttribute("ObjectName") or model.Name
    local subtitle = model:GetAttribute("ObjectSubtitle")
    if subtitle then
        return name .. "\n[" .. subtitle .. "]"
    end
    return name
end

local function addOrUpdateESP(model, color, label)
    local entry = espObjects[model]
    if not entry then
        local h = Instance.new("Highlight")
        h.FillTransparency = 0.65
        h.OutlineTransparency = 0
        h.FillColor = color
        h.OutlineColor = color
        h.Adornee = model
        h.Parent = CoreGui

        local adornee
        if model:IsA("BasePart") then
            adornee = model
        elseif model:IsA("Tool") then
            adornee = model:FindFirstChild("Handle")
        elseif model:IsA("Model") then
            adornee = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
        end

        local b
        if S.espShowNames and adornee then
            b = Instance.new("BillboardGui")
            b.Adornee = adornee
            b.Size = UDim2.fromOffset(120, 36) -- Increased size to accommodate subtitle
            b.AlwaysOnTop = true
            b.StudsOffset = Vector3.new(0, 2, 0)
            b.MaxDistance = 1000
            pcall(function() b.Parent = CoreGui end)
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.fromScale(1, 1)
            lbl.BackgroundTransparency = 1
            lbl.Font = Enum.Font.GothamBold
            lbl.Text = label or getDetailedLabel(model)
            lbl.TextColor3 = color
            lbl.TextStrokeTransparency = 0
            lbl.TextSize = 12
            lbl.Parent = b
        end

        entry = { h = h, b = b, color = color }
        espObjects[model] = entry
    elseif entry.color ~= color then
        entry.h.FillColor = color
        entry.h.OutlineColor = color
        if entry.b then
            local lbl = entry.b:FindFirstChildWhichIsA("TextLabel")
            if lbl then lbl.TextColor3 = color end
        end
        entry.color = color
    end
end

local lastESP = 0
task.spawn(function()
    while getgenv().RustyRaftsCyphraLoaded do
        local hasESP = S.espMobs or S.espLootBox or S.espTools or S.espArmor or S.espDrifting
        if not hasESP then
            if next(espObjects) then clearESP() end
            task.wait(1)
        elseif tick() - lastESP >= 0.6 then
            lastESP = tick()
            local seen = {}

            if S.espMobs then
                for _, m in ipairs(CollectionService:GetTagged("Mob")) do
                    if m:IsA("Model") then
                        local hum = m:FindFirstChildOfClass("Humanoid")
                        if hum and hum.Health > 0 then
                            seen[m] = true
                            addOrUpdateESP(m, ESP_COLORS.Mob, m.Name)
                        end
                    end
                end
            end

            if S.espDrifting then
                for _, m in ipairs(CollectionService:GetTagged("DriftingLoot")) do
                    if m.Parent then
                        seen[m] = true
                        addOrUpdateESP(m, ESP_COLORS.Drifting, getDetailedLabel(m))
                    end
                end
            end

            if S.espLootBox then
                for _, m in ipairs(CollectionService:GetTagged("LootBox")) do
                    if m.Parent and not seen[m] then
                        seen[m] = true
                        addOrUpdateESP(m, ESP_COLORS.LootBox, getDetailedLabel(m))
                    end
                end
                for _, m in ipairs(CollectionService:GetTagged("Draggable")) do
                    if m:IsA("Model") and not seen[m] and m:GetAttribute("ObjectSubtitle") == "Lootable" then
                        seen[m] = true
                        addOrUpdateESP(m, ESP_COLORS.LootBox, getDetailedLabel(m))
                    end
                end
            end

            if S.espTools then
                for _, t in ipairs(Workspace:GetDescendants()) do
                    if t:IsA("Tool") and t:FindFirstChild("Handle") and CollectionService:HasTag(t, "PickupableTool") then
                        seen[t] = true
                        addOrUpdateESP(t, ESP_COLORS.Tool, getDetailedLabel(t))
                    end
                end
            end

            if S.espArmor then
                for _, a in ipairs(CollectionService:GetTagged("ArmorPiece")) do
                    if a.Parent and not seen[a] then
                        seen[a] = true
                        addOrUpdateESP(a, ESP_COLORS.Armor, getDetailedLabel(a))
                    end
                end
            end

            for m, e in pairs(espObjects) do
                if not seen[m] or not m.Parent then
                    if e.h then pcall(function() e.h:Destroy() end) end
                    if e.b then pcall(function() e.b:Destroy() end) end
                    espObjects[m] = nil
                end
            end
        end
        task.wait(0.1)
    end
end)

