-- ==================== UTILITY ====================
local function isVisible(part)
    if not part then return false end
    local origin = camera.CFrame.Position
    local direction = part.Position - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = { player.Character or {} }
    return Workspace:Raycast(origin, direction.Unit * direction.Magnitude, params) == nil
end

local function findNearestMob(maxRange)
    local cam = camera.CFrame
    local closest, closestDist = nil, maxRange or math.huge
    for _, mob in ipairs(CollectionService:GetTagged("Mob")) do
        local hum = mob:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            local hrp = mob:FindFirstChild("HumanoidRootPart") or mob.PrimaryPart
            if hrp then
                local dist = (hrp.Position - cam.Position).Magnitude
                if dist < closestDist then
                    closest = hrp
                    closestDist = dist
                end
            end
        end
    end
    return closest
end

local function getMobInCrosshair()
    if not camera then return nil end
    local lookDir, camPos = camera.CFrame.LookVector, camera.CFrame.Position
    local bestTarget, bestDot = nil, math.cos(math.rad(30))
    for _, mob in ipairs(CollectionService:GetTagged("Mob")) do
        local head = mob:FindFirstChild("Head")
        if head then
            if S.aimbotWallCheck and not isVisible(head) then
                -- skip this mob
            else
                local dir = (head.Position - camPos).Unit
                local dot = lookDir:Dot(dir)
                if dot > bestDot then
                    bestDot = dot
                    bestTarget = head
                end
            end
        end
    end
    return bestTarget
end

local function getEquippedTool()
    local char = player.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") and v:FindFirstChild("Handle") then
            return v
        end
    end
    return nil
end

local function swingAtPosition(targetPos, tool)
    if not remote or not tool then return false end
    local swingId = tostring(math.random() * 100000) .. "_" .. math.random(10000, 99999)
    pcall(function()
        remote:FireServer({
            { swingId = swingId, targetPosition = targetPos, tool = tool },
            "\025"
        })
    end)
    return true
end

