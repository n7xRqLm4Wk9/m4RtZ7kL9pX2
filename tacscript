-- ─── ESP ─────────────────────────────────────────────────────────────────────

local BONES = {
    { "Head",          "Torso"          },
    { "Torso",         "HumanoidRootPart" },
    { "Head",          "UpperTorso"     },
    { "UpperTorso",    "LowerTorso"     },
    { "LowerTorso",    "HumanoidRootPart" },
    { "Torso",         "Left Arm"       },
    { "Torso",         "Right Arm"      },
    { "Torso",         "Left Leg"       },
    { "Torso",         "Right Leg"      },
    { "UpperTorso",    "LeftUpperArm"   },
    { "LeftUpperArm",  "LeftLowerArm"   },
    { "LeftLowerArm",  "LeftHand"       },
    { "UpperTorso",    "RightUpperArm"  },
    { "RightUpperArm", "RightLowerArm"  },
    { "RightLowerArm", "RightHand"      },
    { "LowerTorso",    "LeftUpperLeg"   },
    { "LeftUpperLeg",  "LeftLowerLeg"   },
    { "LeftLowerLeg",  "LeftFoot"       },
    { "LowerTorso",    "RightUpperLeg"  },
    { "RightUpperLeg", "RightLowerLeg"  },
    { "RightLowerLeg", "RightFoot"      },
}

local drawingLines = {}
local billboards   = {}

local function newLine(thick)
    local ok, l = pcall(function()
        local line = Drawing.new("Line")
        line.Visible   = false
        line.Thickness = thick or 1.5
        line.Color     = Color3.new(1, 1, 1)
        return line
    end)
    return ok and l or nil
end

local function clearAllLines()
    for _, lines in pairs(drawingLines) do
        for _, l in ipairs(lines) do
            if l then pcall(l.Remove, l) end
        end
    end
    drawingLines = {}
end

local function getOrCreateLines(npc)
    if drawingLines[npc] then return drawingLines[npc] end
    local lines = {}
    if S.espBox      then for _ = 1, 4       do table.insert(lines, newLine(1.5)) end end
    if S.espTracers  then                        table.insert(lines, newLine(1))   end
    if S.espSkeleton then for _ = 1, #BONES  do table.insert(lines, newLine(1))   end end
    for i = #lines, 1, -1 do
        if not lines[i] then table.remove(lines, i) end
    end
    drawingLines[npc] = lines
    return lines
end 

local function getOrCreateBillboard(npc)
    if billboards[npc] then return billboards[npc] end
    local root = getTorso(npc)
    if not root then return nil end

    local bb = Instance.new("BillboardGui")
    bb.AlwaysOnTop = true
    bb.Size        = UDim2.new(0, 120, 0, 26)
    bb.StudsOffset = Vector3.new(0, 3.2, 0)
    bb.Adornee     = root
    local ok = pcall(function() bb.Parent = CoreGui end)
    if not ok then bb.Parent = player:WaitForChild("PlayerGui") end

    local lbl = Instance.new("TextLabel", bb)
    lbl.Name                   = "Label"
    lbl.Size                   = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3             = Color3.new(1, 1, 1)
    lbl.TextStrokeTransparency = 0.4
    lbl.TextStrokeColor3       = Color3.new(0, 0, 0)
    lbl.TextSize               = 12
    lbl.Font                   = Enum.Font.GothamBold
    lbl.Text                   = ""

    billboards[npc] = bb
    return bb
end

local function stateColor(npc, hum)
    if hum.Health <= 0 then return Color3.fromRGB(130, 130, 130) end
    if isCivilian(npc) then
        return Color3.fromRGB(60, 220, 60)   -- green for civilians
    end
    local state = npc:GetAttribute("State")
    if state == "Investigating" then return Color3.fromRGB(255, 160, 0) end
    return Color3.fromRGB(255, 60, 60)       -- red for hostiles
end

RunService.RenderStepped:Connect(function()
    if not S.espEnabled then
        for _, lines in pairs(drawingLines) do
            for _, l in ipairs(lines) do
                if l then l.Visible = false end
            end
        end
        for _, bb in pairs(billboards) do bb.Enabled = false end
        return
    end

    local vp = Camera.ViewportSize

    for _, npc in ipairs(workspace:GetChildren()) do
        if npc.Name ~= "NPC" then continue end
        local hum = npc:FindFirstChildOfClass("Humanoid")
        if not hum then continue end

        local show  = shouldShowESP(npc)
        local head  = getHead(npc)
        local torso = getTorso(npc)
        local col   = stateColor(npc, hum)

        -- Billboard
        local bb = getOrCreateBillboard(npc)
        if bb then
            bb.Enabled = show
            if show and torso then
                local dist  = math.floor((torso.Position - Camera.CFrame.Position).Magnitude)
                local state = npc:GetAttribute("State") or "Hostile"
                if hum.Health <= 0 then state = "Dead" end
                local lbl = bb:FindFirstChild("Label")
                if lbl then
                    lbl.Text       = state .. "  [" .. dist .. "m]"
                    lbl.TextColor3 = col
                end
            end
        end

        -- Drawing lines
        local lines = getOrCreateLines(npc)
        if not show or not head or not torso or #lines == 0 then
            for _, l in ipairs(lines) do
                if l then l.Visible = false end
            end
            continue
        end

        local idx = 1

        -- Box
        if S.espBox and #lines >= idx + 3 then
            local p1, on1 = Camera:WorldToViewportPoint(head.Position  + Vector3.new(0, 0.7, 0))
            local p2, on2 = Camera:WorldToViewportPoint(torso.Position - Vector3.new(0, 3,   0))
            if on1 and on2 then
                local h  = math.abs(p1.Y - p2.Y)
                local w  = h * 0.55
                local cx = p1.X
                local cy = (p1.Y + p2.Y) / 2
                local corners = {
                    Vector2.new(cx - w/2, cy - h/2),
                    Vector2.new(cx + w/2, cy - h/2),
                    Vector2.new(cx + w/2, cy + h/2),
                    Vector2.new(cx - w/2, cy + h/2),
                }
                for i = 1, 4 do
                    local l = lines[idx+i-1]
                    if l then
                        l.From    = corners[i]
                        l.To      = corners[i % 4 + 1]
                        l.Color   = col
                        l.Visible = true
                    end
                end
            else
                for i = 0, 3 do
                    local l = lines[idx+i]
                    if l then l.Visible = false end
                end
            end
            idx += 4
        end

        -- Tracer
        if S.espTracers and #lines >= idx then
            local pos, on = Camera:WorldToViewportPoint(torso.Position)
            local l = lines[idx]
            if l then
                if on then
                    l.From    = Vector2.new(vp.X / 2, vp.Y)
                    l.To      = Vector2.new(pos.X, pos.Y)
                    l.Color   = col
                    l.Visible = true
                else
                    l.Visible = false
                end
            end
            idx += 1
        end

        -- Skeleton
        if S.espSkeleton then
            for i, bone in ipairs(BONES) do
                local l = lines[idx + i - 1]
                if not l then continue end
                local pA = npc:FindFirstChild(bone[1])
                local pB = npc:FindFirstChild(bone[2])
                if pA and pB then
                    local a, onA = Camera:WorldToViewportPoint(pA.Position)
                    local b, onB = Camera:WorldToViewportPoint(pB.Position)
                    if onA and onB then
                        l.From    = Vector2.new(a.X, a.Y)
                        l.To      = Vector2.new(b.X, b.Y)
                        l.Color   = col
                        l.Visible = true
                    else
                        l.Visible = false
                    end
                else
                    l.Visible = false
                end
            end
        end
    end

    -- Cleanup
    for npc, lines in pairs(drawingLines) do
        if not npc.Parent then
            for _, l in ipairs(lines) do
                if l then pcall(l.Remove, l) end
            end
            drawingLines[npc] = nil
        end
    end
    for npc, bb in pairs(billboards) do
        if not npc.Parent then
            bb:Destroy()
            billboards[npc] = nil
        end
    end
end)

-- ─── Aimbot ───────────────────────────────────────────────────────────────────

local fovCircle
pcall(function()
    fovCircle = Drawing.new("Circle")
    fovCircle.Visible   = false
    fovCircle.Thickness = 1
    fovCircle.Filled    = false
    fovCircle.Color     = Color3.fromRGB(255, 255, 255)
    fovCircle.NumSides  = 64
    fovCircle.Radius    = S.aimbotFov
end)

local function getClosestNPC()
    local center   = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local bestDist = S.aimbotFov
    local bestHead = nil
    for _, npc in ipairs(workspace:GetChildren()) do
        if npc.Name ~= "NPC" then continue end
        local hum  = npc:FindFirstChildOfClass("Humanoid")
        local head = getHead(npc)
        if not hum or not head or hum.Health <= 0 or not isHostile(npc) then continue end
        local pos, on = Camera:WorldToViewportPoint(head.Position)
        if not on then continue end
        local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
        if d < bestDist and isVisible(head, npc) then
            bestDist = d; bestHead = head
        end
    end
    return bestHead
end

local aimbotConn

local function startAimbot()
    if aimbotConn then aimbotConn:Disconnect() end
    aimbotConn = RunService.RenderStepped:Connect(function()
        if not S.aimbotEnabled then return end
        local vp = Camera.ViewportSize
        if fovCircle then
            fovCircle.Position = Vector2.new(vp.X / 2, vp.Y / 2)
            fovCircle.Radius   = S.aimbotFov
            fovCircle.Visible  = true
        end
        local target = getClosestNPC()
        if target then
            local alpha = math.clamp((11 - S.aimbotSmoothness) * 0.1, 0.01, 1)
            Camera.CFrame = Camera.CFrame:Lerp(
                CFrame.new(Camera.CFrame.Position, target.Position), alpha
            )
        end
    end)
end

local function stopAimbot()
    S.aimbotEnabled = false
    if aimbotConn then aimbotConn:Disconnect(); aimbotConn = nil end
    if fovCircle then fovCircle.Visible = false end
end

-- ─── Anti-Death ───────────────────────────────────────────────────────────────

local function antiDeathLoop()
    while S.antiDeathEnabled do
        task.wait(0.5)
        local char = player.Character
        if char and not S.antiDeathTriggered then
            local hum  = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.Health > 0 and hum.Health <= 20 then
                S.antiDeathTriggered = true
                local origY = root.Position.Y
                root.CFrame = root.CFrame + Vector3.new(0, 200, 0)
                Rayfield:Notify({ Title = "Anti-Death", Content = "Teleported up 200 studs. Returning in 10s.", Duration = 5, Image = 4483362458 })
                task.delay(10, function()
                    if root and root.Parent then
                        root.CFrame = CFrame.new(root.Position.X, origY, root.Position.Z)
                        Rayfield:Notify({ Title = "Anti-Death", Content = "Returned to original height.", Duration = 3, Image = 4483362458 })
                    end
                    S.antiDeathTriggered = false
                end)
            end
        end
    end
end

-- ─── Bring NPCs ───────────────────────────────────────────────────────────────

local function bringAllNPCs()
    local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local count, offset = 0, 0
    for _, npc in ipairs(workspace:GetChildren()) do
        if npc.Name ~= "NPC" then continue end
        local root = npc:FindFirstChild("HumanoidRootPart")
        local hum  = npc:FindFirstChildOfClass("Humanoid")
        if root and hum and hum.Health > 0 then
            root.CFrame = myRoot.CFrame + Vector3.new(offset, 3, 0)
            count  += 1
            offset += 3
        end
    end
    Rayfield:Notify({ Title = "NPCs", Content = "Brought " .. count .. " NPC(s).", Duration = 3, Image = 4483362458 })
end

-- ─── Performance Mode ────────────────────────────────────────────────────────

local function enablePerformanceMode()
    local bloom = Lighting:FindFirstChildOfClass("BloomEffect")
    if bloom then bloom.Enabled = false end
    for _, p in ipairs(workspace:GetDescendants()) do
        if p:IsA("BasePart") then
            pcall(function() p.Material = Enum.Material.SmoothPlastic end)
        end
    end
    Rayfield:Notify({ Title = "Performance", Content = "Performance mode applied.", Duration = 3, Image = 4483362458 })
end

