-- ─── NPC Classification (spawn proximity + State) ─────────────────────────────

local npcTypeCache = {}
local SPAWN_PROXIMITY = 20

local function classifyNPC(npc)
    if npcTypeCache[npc] then return npcTypeCache[npc] end
    local hrp = npc:FindFirstChild("HumanoidRootPart")
    if not hrp then return "hostile" end
    local round = workspace:FindFirstChild("Round")
    if not round then return "hostile" end
    local enemyFolder = round:FindFirstChild("EnemyPOS")
    local civFolder = round:FindFirstChild("CivilianPOS")
    local closestEnemyDist = math.huge
    local closestCivDist = math.huge
    if enemyFolder then
        for _, part in ipairs(enemyFolder:GetChildren()) do
            if part:IsA("BasePart") then
                local d = (hrp.Position - part.Position).Magnitude
                if d < closestEnemyDist then closestEnemyDist = d end
            end
        end
    end
    if civFolder then
        for _, part in ipairs(civFolder:GetChildren()) do
            if part:IsA("BasePart") then
                local d = (hrp.Position - part.Position).Magnitude
                if d < closestCivDist then closestCivDist = d end
            end
        end
    end
    if closestEnemyDist < SPAWN_PROXIMITY or closestCivDist < SPAWN_PROXIMITY then
        if closestEnemyDist < closestCivDist then
            npcTypeCache[npc] = "hostile"
            return "hostile"
        else
            npcTypeCache[npc] = "civilian"
            return "civilian"
        end
    end
    -- fallback to State attribute
    local state = npc:GetAttribute("State")
    local nonHostile = {Idle=true, Surrendered=true, Hesitating=true, ShoutHesitation=true, Stunned=true, Down=true, Tased=true}
    if nonHostile[state] then
        npcTypeCache[npc] = "civilian"
        return "civilian"
    end
    npcTypeCache[npc] = "hostile"
    return "hostile"
end

workspace.ChildRemoved:Connect(function(child)
    if child.Name == "NPC" then npcTypeCache[child] = nil end
end)

local function isHostile(npc) return classifyNPC(npc) == "hostile" end
local function isCivilian(npc) return classifyNPC(npc) == "civilian" end
local function shouldShowESP(npc)
    if not isCivilian(npc) then return true end
    return S.showCivilians
end

-- ─── Part Finders ────────────────────────────────────────────────────────────

local function getHead(npc)
    local highest
    for _, p in ipairs(npc:GetChildren()) do
        if p:IsA("BasePart") and (not highest or p.Position.Y > highest.Position.Y) then
            highest = p
        end
    end
    return highest
end

local function getTorso(npc)
    local cf = npc:GetBoundingBox()
    if not cf then return nil end
    local center = cf.Position
    local closest, closestDist = nil, math.huge
    for _, p in ipairs(npc:GetChildren()) do
        if p:IsA("BasePart") then
            local d = (p.Position - center).Magnitude
            if d < closestDist then closestDist = d; closest = p end
        end
    end
    return closest
end

-- ─── Wall Check ──────────────────────────────────────────────────────────────

local function isVisible(part, model)
    if not part or not model then return false end
    local origin = Camera.CFrame.Position
    local dir    = part.Position - origin
    if dir.Magnitude == 0 then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = { player.Character or {}, model }
    return Workspace:Raycast(origin, dir.Unit * dir.Magnitude, params) == nil
end

